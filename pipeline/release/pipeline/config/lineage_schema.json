{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axis-niddhi:cls:lineage:1.1",
  "title": "Content Lineage System — Lineage Block Schema V1.1",
  "description": "Genealogia criptográfica completa de um post CSL desde HTML original até publicação. Embedded dentro do identity.json de cada entry. Compatível com schema_version 3.1 sem quebrar campos existentes.",
  "cls_version": "1.1",
  "sprint": "AXIS-NIDDHI V5.2.1",
  "changelog": {
    "1.0": "V5.2 — estrutura inicial: origin flat, translation_history, publication_history, flags",
    "1.1": "V5.2.1 — hardening criptográfico: origin com source_html_sha256, csl block, transformations separado de translations, compatibilidade retroativa V1.0→V1.1"
  },

  "embedding_note": "Este bloco é adicionado como campo 'lineage' dentro do identity.json existente. Não substitui nenhum campo atual (schema_version, identity, sro, titles, artifacts).",

  "lineage_block": {
    "type": "object",
    "required": ["cls_version", "origin", "csl"],
    "properties": {

      "cls_version": {
        "type": "string",
        "description": "Versão do schema CLS.",
        "example": "1.1"
      },

      "origin": {
        "type": "object",
        "description": "Rastreabilidade do HTML de origem no WordPress.",
        "properties": {
          "wp_post_id": {
            "type": ["integer", "null"],
            "description": "ID do post no WordPress de origem.",
            "example": 12345
          },
          "source_html": {
            "type": ["string", "null"],
            "description": "Nome do arquivo HTML original extraído do WordPress.",
            "example": "WP_12345_dhamma-and-science.html"
          },
          "source_html_sha256": {
            "type": ["string", "null"],
            "description": "SHA-256 do HTML bruto extraído — auditoria criptográfica da origem.",
            "example": "c9a1f3..."
          },
          "extracted_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Timestamp UTC da extração (SG01).",
            "example": "2026-03-07T10:00:00Z"
          }
        }
      },

      "csl": {
        "type": "object",
        "description": "Metadados da entry CSL criada a partir da origem.",
        "properties": {
          "pdpn": {
            "type": ["string", "null"],
            "description": "Identificador único do post no CSL.",
            "example": "PD.BU.001"
          },
          "schema_version": {
            "type": "string",
            "description": "Versão do schema CSL do identity.json.",
            "example": "3.1"
          },
          "created_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Timestamp UTC de criação da entry CSL (SG03).",
            "example": "2026-03-07T14:22:00Z"
          }
        }
      },

      "transformations": {
        "type": "array",
        "description": "Log append-only de transformações do pipeline sobre o conteúdo (preprocess, migrations, header fixes, etc.).",
        "items": {
          "type": "object",
          "required": ["step", "utc"],
          "properties": {
            "step": {
              "type": "string",
              "description": "Nome do script/etapa que realizou a transformação.",
              "example": "SG02_preprocess"
            },
            "utc": { "type": "string", "format": "date-time" },
            "input_hash":  { "type": ["string", "null"], "description": "SHA-256 do content.html antes da transformação." },
            "output_hash": { "type": ["string", "null"], "description": "SHA-256 do content.html após a transformação." },
            "note":        { "type": ["string", "null"] }
          }
        }
      },

      "translations": {
        "type": "array",
        "description": "Log append-only de eventos de tradução EN→PT. Substitui translation_history (V1.0). Durante upgrade V1.0→V1.1, translation_history é migrado automaticamente para cá.",
        "items": {
          "type": "object",
          "required": ["lang", "event", "utc", "engine"],
          "properties": {
            "lang":        { "type": "string", "example": "pt-BR" },
            "event":       { "type": "string", "enum": ["translated", "retranslated", "title_translated", "glossary_updated", "manual_edit"] },
            "engine":      { "type": "string", "example": "SP10_translate_deepl_v5.2" },
            "utc":         { "type": "string", "format": "date-time" },
            "source_hash": { "type": ["string", "null"], "description": "SHA-256 do content.html EN antes da tradução." },
            "result_hash": { "type": ["string", "null"], "description": "SHA-256 do content.html PT após a tradução." },
            "deepl_chars": { "type": ["integer", "null"] },
            "glossary_id": { "type": ["string", "null"] },
            "note":        { "type": ["string", "null"] }
          }
        }
      },

      "publication_history": {
        "type": "array",
        "description": "Log append-only de injeções no WordPress (SD04).",
        "items": {
          "type": "object",
          "required": ["event", "utc"],
          "properties": {
            "event":      { "type": "string", "enum": ["injected", "updated", "failed"] },
            "utc":        { "type": "string", "format": "date-time" },
            "wp_post_id": { "type": ["integer", "null"] },
            "wp_lang":    { "type": ["string", "null"], "example": "pt-BR" },
            "engine":     { "type": ["string", "null"] }
          }
        }
      },

      "flags": {
        "type": "object",
        "properties": {
          "needs_retranslation": { "type": "boolean", "default": false },
          "manual_pt_edit":      { "type": "boolean", "default": false },
          "glossary_mismatch":   { "type": "boolean", "default": false }
        }
      }
    }
  },

  "example_embedded": {
    "schema_version": "3.1",
    "last_updated_utc": "2026-03-08T00:00:00Z",
    "identity": { "pdpn": "PD.BU.001", "findex": "0001", "slug_root": "dhamma-and-science", "section_code": "PD" },
    "sro": { "source": "PureDhamma.net", "url": null, "original_wp_id": 12345, "author": "Lal A." },
    "titles": { "en": "Dhamma and Science", "en_source": "h1", "pt": "Dhamma e Ciência", "pt_source": "SP11_deepl" },
    "artifacts": {
      "en-US": { "status": "canonical", "file_path": "source/en-US/content.html", "integrity_sha256": "a3f1c2...", "last_audit": "2026-03-08T00:00:00Z" },
      "pt-BR": { "status": "derived",   "file_path": "source/pt-BR/content.html", "integrity_sha256": "b7d9e4...", "last_audit": "2026-03-08T00:00:00Z" }
    },
    "lineage": {
      "cls_version": "1.1",
      "origin": {
        "wp_post_id": 12345,
        "source_html": "WP_12345_dhamma-and-science.html",
        "source_html_sha256": "c9a1f3...",
        "extracted_at": "2026-03-07T10:00:00Z"
      },
      "csl": {
        "pdpn": "PD.BU.001",
        "schema_version": "3.1",
        "created_at": "2026-03-07T14:22:00Z"
      },
      "transformations": [
        { "step": "SG02_preprocess", "utc": "2026-03-07T14:20:00Z", "input_hash": "c9a1f3...", "output_hash": "d4b2e1...", "note": null },
        { "step": "SP05_fix_headers", "utc": "2026-03-07T15:00:00Z", "input_hash": "d4b2e1...", "output_hash": "a3f1c2...", "note": null }
      ],
      "translations": [
        { "lang": "pt-BR", "event": "title_translated", "engine": "SP11_v5.2", "utc": "2026-03-08T10:00:00Z", "source_hash": "a3f1c2...", "result_hash": null,       "deepl_chars": 18,    "glossary_id": "glossario_v5_xxxx", "note": null },
        { "lang": "pt-BR", "event": "translated",       "engine": "SP10_v5.2", "utc": "2026-03-08T12:00:00Z", "source_hash": "a3f1c2...", "result_hash": "b7d9e4...", "deepl_chars": 14320, "glossary_id": "glossario_v5_xxxx", "note": null }
      ],
      "publication_history": [],
      "flags": { "needs_retranslation": false, "manual_pt_edit": false, "glossary_mismatch": false }
    }
  }
}
