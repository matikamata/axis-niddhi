{
  "$schema": "AXIS-SEMANTIC-CONCEPT-1.0",
  "description": "Schema for a semantic concept entry in the AXIS semantic layer",
  "fields": {
    "concept": "string — canonical slug (lowercase, ASCII)",
    "type": "string — dhamma_characteristic | attainment | practice | mental_factor | doctrine | person | place | text | other",
    "pali": "string — Pāli term with diacritics",
    "translations": "object — {lang_code: translated_term}",
    "description": "string — one-line description",
    "first_occurrence": "string — PDPN of first CSL entry mentioning this concept",
    "occurrences": "array — [PDPN, ...] sorted by findex",
    "related": "array — [concept_slug, ...] related concepts",
    "glossary_refs": "array — matching terms from Glossario_v5.csv",
    "schema_version": "string — concept schema version"
  },
  "concept_types": [
    "dhamma_characteristic",
    "attainment",
    "practice",
    "mental_factor",
    "doctrine",
    "person",
    "place",
    "text",
    "other"
  ],
  "pdpn_pattern": "^[A-Z]{2}\\.[A-Z]{2}\\.\\d{3}$"
}