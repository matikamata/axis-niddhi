# AXIS-NIDDHI — Root .gitignore
# ============================================================
# SECURITY — NEVER commit credentials or personal data
# ============================================================

# Credential files — create these manually on each machine
pipeline/scripts/private/deepl_key.txt
pipeline/scripts/private/wp_password.txt
pipeline/scripts/private/github_token.txt
pipeline/scripts/core/deepl_key.txt
pipeline/scripts/core/wp_password.txt

# Environment
.env
.venv/
env/

# Release snap equivalents
release/pipeline/scripts/private/
release/pipeline/scripts/core/deepl_key.txt
release/pipeline/scripts/core/wp_password.txt

# ============================================================
# SOURCE CORPUS — copyrighted, obtain from PureDhamma.net
# ============================================================

pipeline/sources/*.zip
release/sources/*.zip
sources/*.zip

# ============================================================
# GENERATED OUTPUT — rebuilt by the pipeline
# ============================================================

pipeline/09-csl/*
!pipeline/09-csl/.gitkeep
pipeline/03-translations/*
!pipeline/03-translations/.gitkeep
# pipeline/13-static-site/*
# !pipeline/13-static-site/.gitkeep
pipeline/01-extracted-htmls/*
!pipeline/01-extracted-htmls/.gitkeep
pipeline/02-preprocessed/*
!pipeline/02-preprocessed/.gitkeep
pipeline/snapshots/*
!pipeline/snapshots/.gitkeep
pipeline/recovery/*
!pipeline/recovery/.gitkeep

# ============================================================
# LOGS — operational artifacts, not part of the corpus
# ============================================================

pipeline/logs/*.log
pipeline/scripts/legacy/resultado_passo10.txt

# ============================================================
# PYTHON CACHE
# ============================================================

__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ============================================================
# EDITOR / SYSTEM
# ============================================================

.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# SHOWCASE / MUSEUM
# ============================================================
DEPRECATED/


# Bloqueio de arquivos pesados e backups
*.zip
pipeline/09-csl/meta/pronunciation/**
pipeline/13-static-site/assets/audio/**
# Garante que não vamos subir áudios MP3/WAV perdidos em outras pastas
*.mp3
*.wav
*.mp4
