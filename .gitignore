# AXIS-NIDDHI — Root .gitignore
# ============================================================
# SECURITY — NEVER commit credentials or personal data
# ============================================================

# Credential files — create these manually on each machine
pipeline/scripts/private/deepl_key.txt
pipeline/scripts/private/wp_password.txt
pipeline/scripts/private/github_token.txt
pipeline/scripts/core/deepl_key.txt
pipeline/scripts/core/wp_password.txt

# Environment
.env
.venv/
env/

# Release snap equivalents
release/pipeline/scripts/private/
release/pipeline/scripts/core/deepl_key.txt
release/pipeline/scripts/core/wp_password.txt

# ============================================================
# SOURCE CORPUS — copyrighted, obtain from PureDhamma.net
# ============================================================

pipeline/sources/*.zip
release/sources/*.zip
sources/*.zip

# ============================================================
# GENERATED OUTPUT — rebuilt by the pipeline
# ============================================================

pipeline/09-csl/*
!pipeline/09-csl/.gitkeep
pipeline/03-translations/*
!pipeline/03-translations/.gitkeep
pipeline/13-static-site/*
!pipeline/13-static-site/.gitkeep
pipeline/01-extracted-htmls/*
!pipeline/01-extracted-htmls/.gitkeep
pipeline/02-preprocessed/*
!pipeline/02-preprocessed/.gitkeep
pipeline/snapshots/*
!pipeline/snapshots/.gitkeep
pipeline/recovery/*
!pipeline/recovery/.gitkeep
/beng-release/
/snapshots/
/*.sql

# ============================================================
# LOGS — operational artifacts, not part of the corpus
# ============================================================

pipeline/logs/*.log
pipeline/scripts/legacy/resultado_passo10.txt

# ============================================================
# PYTHON CACHE
# ============================================================

__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ============================================================
# EDITOR / SYSTEM
# ============================================================

.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# SHOWCASE / MUSEUM
# ============================================================
DEPRECATED/


# Bloqueio de arquivos pesados e backups
*.zip
pipeline/09-csl/meta/pronunciation/**
pipeline/13-static-site/assets/audio/**
# Garante que não vamos subir áudios MP3/WAV perdidos em outras pastas
*.mp3
*.wav
*.mp4
AUTHORIZATION_LETTER.md
.venv_test/
venv/
__pycache__/

# ============================================================
# LOCAL DEVELOPMENT — Playground and testing scripts
# ============================================================
The-Skunkworks-Sublime-Saga/

# Bloqueio de artefatos temporários (Cleanup SRE)
.~lock.*#

# PDFs gerados pelo Batch Print Engine (temporários locais)
pipeline/print_output/

# Node modules (Netlify CLI etc)
node_modules/
package.json
package-lock.json

# Local Netlify folder
.netlify

# ============================================================
# PROJETOS PARALELOS — ficam no disco mas fora do repo
# ============================================================
axis
axis-cli/
axis-mirror/
axis-nana/
axis-navigator/
axis-preservation/

# ============================================================
# WORDPRESS RUNTIME — ephemeral workspace, NEVER commit
# Dados sensíveis: uploads, config.php, wp-config.php
# Reconstruído via: python3 pipeline/S14_asset_resolver/S14_prepare_wp.py
# ============================================================
/wordpress/
wordpress/

# Generated static site output
pipeline/13-static-site/*
!pipeline/13-static-site/.gitkeep

# Root-level release and snapshots
/beng-release/
/snapshots/
/*.sql

# Release workspace generated artifacts
pipeline/release/pipeline/01-extracted-htmls/
pipeline/release/pipeline/02-preprocessed/
pipeline/release/pipeline/09-csl/
pipeline/release/pipeline/13-static-site/
pipeline/release/pipeline/S14_asset_resolver/
pipeline/release/pipeline/logs/
pipeline/release/pipeline/13-ssg/cache/

# Release workspace generated metadata
pipeline/release/pipeline/metadata/Translation_Control_Center.csv
pipeline/release/pipeline/metadata/glossary_config.json
pipeline/release/pipeline/metadata/slug_map.json
pipeline/release/pipeline/metadata/translation_status.json
pipeline/release/pipeline/mission_report.txt

# Secrets
pipeline/release/pipeline/scripts/wp_password.txt
pipeline/scripts/private/

# Local logs
logs/
